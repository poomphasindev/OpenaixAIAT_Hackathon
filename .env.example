OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

OPENAQ_API_KEY=your-openaq-api-key
OPENAQ_BASE_URL=https://api.openaq.org/v3
# 418 is a Bangkok-area Thailand location with a PM2.5 sensor in OpenAQ.
OPENAQ_LOCATION_ID=418

TMD_API_KEY=your-thai-meteorological-department-api-key
TMD_UID=api
# If your TMD guide gives a different endpoint, paste it here. `{key}` is also supported.
TMD_WEATHER_URL=https://data.tmd.go.th/api/WeatherToday/V1/?uid=api&format=json

NEXT_PUBLIC_DEFAULT_LANGUAGE=en
